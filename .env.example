APP_NAME=ParKar
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-backend-domain.up.railway.app
FRONTEND_URL=https://your-frontend-domain.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:5173

LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DATABASE_URL=
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=prefer
DB_SSLROOTCERT=
MYSQL_ATTR_SSL_CA=
MYSQL_ATTR_SSL_VERIFY_SERVER_CERT=true

FILESYSTEM_DISK=public

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="ParKar"

JWT_SECRET=
JWT_TTL_MINUTES=60

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-backend-domain.up.railway.app/api/auth/google/callback
GOOGLE_FRONTEND_REDIRECT_URI=https://your-frontend-domain/auth/google/success

AI_SERVICE_URL=
AI_SERVICE_TIMEOUT=30

ADMIN_EMAILS=
TEACHER_EMAILS=
